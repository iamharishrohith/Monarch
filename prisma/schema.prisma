generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContentStatus {
  DRAFT
  PUBLISHED
}

enum NotificationKind {
  LEVEL_UP
  RANK_UP
  EXP_GAIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model Profile {
  id             String   @id @default(cuid())
  headline       String
  subheadline    String
  bio            String
  avatarUrl      String?
  location       String?
  phone          String?
  email          String?
  githubUrl      String?
  linkedinUrl    String?
  leetcodeUrl    String?
  xUrl           String?
  websiteUrl     String?
  resumeUrl      String?
  yearsOfExp     Int      @default(0)
  statsSummary   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Project {
  id           String        @id @default(cuid())
  slug         String        @unique
  title        String
  summary      String
  description  String
  stack        String
  coverImage   String?
  repoUrl      String?
  liveUrl      String?
  caseStudyUrl String?
  impact       String?
  featured     Boolean       @default(false)
  status       ContentStatus @default(DRAFT)
  expValue     Int           @default(250)
  sortOrder    Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Skill {
  id          String        @id @default(cuid())
  name        String
  category    String
  description String
  level       Int           @default(1)
  featured    Boolean       @default(false)
  status      ContentStatus @default(PUBLISHED)
  expValue    Int           @default(80)
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Experience {
  id          String        @id @default(cuid())
  company     String
  role        String
  location    String?
  startDate   DateTime
  endDate     DateTime?
  summary     String
  highlights  String
  status      ContentStatus @default(PUBLISHED)
  expValue    Int           @default(180)
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Certification {
  id           String        @id @default(cuid())
  title        String
  issuer       String
  issueDate    DateTime
  credentialId String?
  credentialUrl String?
  imageUrl     String?
  status       ContentStatus @default(PUBLISHED)
  expValue     Int           @default(120)
  sortOrder    Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Achievement {
  id          String        @id @default(cuid())
  title       String
  summary     String
  awardedBy   String?
  awardedAt   DateTime
  imageUrl    String?
  status      ContentStatus @default(PUBLISHED)
  expValue    Int           @default(140)
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Post {
  id           String        @id @default(cuid())
  slug         String        @unique
  title        String
  excerpt      String
  content      String
  coverImage   String?
  tags         String
  publishedAt  DateTime?
  status       ContentStatus @default(DRAFT)
  expValue     Int           @default(100)
  readTime     Int           @default(5)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model RankTier {
  id          String  @id @default(cuid())
  title       String  @unique
  minLevel    Int     @unique
  badge       String?
  description String?
  sortOrder   Int     @default(0)
}

model ExpRule {
  id              String @id @default(cuid())
  entityType      String @unique
  baseExp         Int
  publishedOnly   Boolean @default(true)
  multiplier      Float   @default(1)
  bonusThreshold  Int?
  bonusExp        Int     @default(0)
}

model ProgressSnapshot {
  id               String   @id @default(cuid())
  totalExp         Int
  currentLevel     Int
  currentRank      String
  nextLevelExp     Int
  levelProgressExp Int
  levelStartExp    Int
  levelEndExp      Int
  statsJson        String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model NotificationEvent {
  id          String           @id @default(cuid())
  kind        NotificationKind
  title       String
  message     String
  metadata    String?
  acknowledged Boolean         @default(false)
  createdAt   DateTime         @default(now())
}

model SiteSettings {
  id                      String   @id @default(cuid())
  siteTitle               String
  siteDescription         String
  heroPrimaryCtaLabel     String
  heroPrimaryCtaHref      String
  heroSecondaryCtaLabel   String
  heroSecondaryCtaHref    String
  levelLabel              String   @default("S-Rank - Monarch")
  servicesJson            String?
  constellationQuotes     String?
  skillMapLayoutJson      String?
  pinnedProjectSlugs      String?
  lastPublishedAt         DateTime?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}
